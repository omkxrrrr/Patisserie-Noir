# ─────────────────────────────────────────────────────────────────
# Patisserie Noir — Environment Variables
# Copy this file to .env.local and fill in real values.
# Vite only exposes variables prefixed with VITE_ to the browser.
# Never commit .env.local.
# ─────────────────────────────────────────────────────────────────

# 1. Google Apps Script Web App URL (your deployed backend).
#    See /google-apps-script/README.md for deployment steps.
#    Looks like: https://script.google.com/macros/s/XXXXXXXX/exec
VITE_APPS_SCRIPT_URL=

# 2. A shared secret the frontend sends with every request so random
#    people can't hit your Apps Script URL directly. Set the SAME value
#    in Script Properties (key: API_SECRET) in the Apps Script project.
#    Generate one with: openssl rand -hex 24
VITE_API_SECRET=

# 3. Shop identity (used in headers, footers, invoices, WhatsApp links, SEO)
VITE_SHOP_NAME="Patisserie Noir"
VITE_SHOP_PHONE="+91 98765 43210"
VITE_SHOP_WHATSAPP_NUMBER="919876543210"
VITE_SHOP_EMAIL="hello@patisserienoir.example"
VITE_SHOP_ADDRESS="12 Bandra Bakery Lane, Mumbai, Maharashtra"
VITE_SHOP_GST_NUMBER=
VITE_SHOP_INSTAGRAM_HANDLE="patisserienoir"

# 4. Google Maps — only needed for the address picker on the order form.
#    Restrict this key to your domain in Google Cloud Console.
VITE_GOOGLE_MAPS_API_KEY=

# 5. Currency + locale formatting
VITE_CURRENCY=INR
VITE_LOCALE=en-IN
